<% layout("/layouts/boilerplate") %>
    <style>
        #filters{
            display: flex;
            flex-wrap: wrap;
            align-items: center;
        }
        .filter{
            text-align: center;
            margin-right: 2rem;
            margin-top: 2rem;
            opacity: 0.7;
        }
        .filter:hover{
            opacity: 1;
            cursor: pointer;
        }
        .filter.active{
            opacity: 1;
        }
        .filter-link{
            text-decoration: none;
            color: inherit;
        }
        .filter p {
            font-size: 0.8rem;
        }
        .tax-info{
            display: none;
        }
        .tax-toggle{
            border: 1px solid black;
            border-radius: 1rem;
            height: 3.25rem;
            padding: 1rem;
            margin-left: 2rem;
            display: flex;
            align-items: center;
        }
    </style>
    <% const filters = [
        { key: "trending", icon: "fa-solid fa-fire", label: "Trending" },
        { key: "rooms", icon: "fa-solid fa-bed", label: "Room" },
        { key: "iconic-cities", icon: "fa-solid fa-mountain-city", label: "Iconic Cities" },
        { key: "mountains", icon: "fa-solid fa-mountain", label: "Mountains" },
        { key: "castles", icon: "fa-brands fa-fort-awesome", label: "Castles" },
        { key: "pools", icon: "fa-solid fa-person-swimming", label: "Amazing Pools" },
        { key: "camping", icon: "fa-solid fa-campground", label: "Camping" },
        { key: "farms", icon: "fa-solid fa-cow", label: "Farms" },
        { key: "arctic", icon: "fa-solid fa-snowflake", label: "Arctic" },
        { key: "domes", icon: "fa-solid fa-igloo", label: "Domes" },
        { key: "boats", icon: "fa-solid fa-ship", label: "Boats" }
    ]; %>
    <div id="filters">
        <% for(let filter of filters) { %>
            <a 
                href="/listings?<%= new URLSearchParams({
                    ...(searchQuery ? { search: searchQuery } : {}),
                    ...(filter.key !== 'trending' ? { category: filter.key } : {})
                }).toString() %>" 
                class="filter-link"
            >
                <div class="filter <%= (activeCategory === filter.key || (!activeCategory && filter.key === 'trending')) ? 'active' : '' %>">
                    <div><i class="<%= filter.icon %>"></i></div>
                    <p><%= filter.label %></p>
                </div>
            </a>
        <% } %>
        <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
            </div>
        </div>
    </div>
    <% if(activeCategory) { %>
        <p class="mt-3 mb-0">
            Filter applied: <b><%= filters.find((filter) => filter.key === activeCategory)?.label || activeCategory %></b>
        </p>
    <% } %>
    <% if(searchQuery) { %>
        <p class="mt-3 mb-0">
            Search results for <b>"<%= searchQuery %>"</b>
        </p>
    <% } %>

    <% if(allListings.length === 0) { %>
        <div class="alert alert-secondary mt-3" role="alert">
            No listings found<% if(searchQuery) { %> for "<%= searchQuery %>"<% } %>.
        </div>
    <% } %>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
        <% for(let listing of allListings){ %>
        <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card col listing-card">
            <img src="<%= listing.image.url %>" 
            class="card-img-top" 
            alt="listing_image" 
            style="height: 20rem" 
            />
            <div class="card-img-overlay"></div>
            <div class="card-body">
                <p class="card-text">
                    <b><%= listing.title %> <br></b>
                    <span 
                        class="listing-price" 
                        data-base-price="<%= listing.price %>"
                    >
                        &#8377; <%= listing.price.toLocaleString("en-IN") %>
                    </span> / night
                    <i class="tax-info">&nbsp; &nbsp;+18% GST included</i>
                </p>
            </div>
        </div>
        </a>
        <% } %>
    </div>

    <script>
        let taxSwitch = document.getElementById("flexSwitchCheckDefault");
        taxSwitch.addEventListener("click", ()=> {
            let taxInfo = document.getElementsByClassName("tax-info");
            let listingPrices = document.getElementsByClassName("listing-price");

            for(info of taxInfo){
                if(info.style.display != "inline"){
                    info.style.display = "inline";
                } else{
                    info.style.display = "none";
                } 
            }

            for(let priceElement of listingPrices){
                let basePrice = Number(priceElement.dataset.basePrice);
                let finalPrice = taxSwitch.checked 
                    ? Math.round(basePrice * 1.18)
                    : basePrice;

                priceElement.innerHTML = `&#8377; ${finalPrice.toLocaleString("en-IN")}`;
            }
        });
    </script>
